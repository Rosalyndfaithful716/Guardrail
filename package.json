{
  "name": "guardrail",
  "version": "0.2.1",
  "private": true,
  "description": "Scan and fix AI-generated code for security, performance, and quality issues",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "dev": "tsx packages/cli/src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf packages/*/dist",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "tsc --build"
  },
  "keywords": [
    "security",
    "code-quality",
    "ast",
    "static-analysis",
    "ai-code",
    "guardrail"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/node": "^20.11.0",
    "@vitest/coverage-v8": "^2.1.9",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
