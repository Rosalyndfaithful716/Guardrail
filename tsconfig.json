{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "composite": true
  },
  "exclude": ["website", "node_modules"],
  "references": [
    { "path": "packages/core" },
    { "path": "packages/rules" },
    { "path": "packages/fixer" },
    { "path": "packages/cli" },
    { "path": "packages/mcp" }
  ],
  "files": []
}
